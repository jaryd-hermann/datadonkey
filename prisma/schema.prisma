generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Single-tenant prototype: there is exactly one Connection row.
// id is hardcoded to "default" so we can upsert.
model Connection {
  id           String   @id @default("default")

  // Mock signup info
  userName     String?
  userCompany  String?
  userEmail    String?

  // Which data tool the user picked, plus its provider-specific credentials
  // stored as a JSON blob. Shape depends on provider — see lib/providers.ts.
  provider     String   @default("posthog")
  credentials  String?

  // Preferences (at least one must be true to make sense of the product).
  // Hey-PostHog live mode is opt-in (rough UX); fast-follows is the default.
  prefLive     Boolean  @default(false)
  prefFollowup Boolean  @default(true)

  // Lifecycle emails — set on send so we don't double-send
  welcomeEmailedAt    DateTime?
  firstCallEmailedAt  DateTime?

  // Calendar (Google) OAuth state
  calendarConnected Boolean  @default(false)
  calendarProvider  String?  // "google"
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleEmail        String?

  // Slack OAuth state
  slackConnected    Boolean  @default(false)
  slackTeamName     String?
  slackTeamId       String?
  slackBotToken     String?
  slackUserId       String?
  slackBotUserId    String?

  updatedAt    DateTime @updatedAt
}

model Meeting {
  id            String     @id @default(cuid())
  recallBotId   String     @unique
  meetingUrl    String
  title         String?
  status        String
  createdAt     DateTime   @default(now())
  endedAt       DateTime?
  participants  String?    // JSON: [{name, email?}]
  transcript    String?    // formatted as "Speaker: text\n…"
  followups     String?    // JSON: [{question, reasoning, answer?, posthogUrls?[]}]
  followupsAt   DateTime?
  emailSubject  String?
  emailDraft    String?
  emailDraftAt  DateTime?
  followupReport     String?    // markdown rendered as the rich report body
  followupEmailedAt  DateTime?
  followupSlackedAt  DateTime?
  followupAttempted  Boolean    @default(false)
  // In-call state, persisted so we work on Vercel (serverless = no shared mem)
  welcomed       Boolean    @default(false)
  armedUntil     DateTime?
  lastTriggerAt  DateTime?
  // Per-bot conversation history for follow-up question context
  conversation   String?    // JSON: [{role:"user"|"assistant", content:string}]

  // Pipeline timeline (rendered as the big status bar on the dashboard).
  // pipelineStage: current stage label (one of listening, reviewing,
  // analyzing, querying, delivering, done, failed).
  // pipelineStages: JSON array of {stage, ts, ok?} entries marking history.
  pipelineStage      String?
  pipelineStageAt    DateTime?
  pipelineStages     String?

  // Whether the user has dismissed the big status banner once the call is
  // fully wrapped up. (Optional UX touch — pipeline stays in the meeting card.)
  pipelineDismissed  Boolean  @default(false)

  // Calendar event we joined for, if dispatched via auto-join.
  calendarEventId    String?  @unique

  questions     Question[]
}

// Per-event opt-in/out for upcoming calendar events. Default behavior is
// "join all events with a meeting link"; rows here mark explicit user
// overrides. We also drop a row in here when an event has been dispatched
// (botId set) so the cron sync doesn't re-dispatch.
model CalendarEventPolicy {
  id          String   @id @default(cuid())
  eventId     String   @unique
  skip        Boolean  @default(false)  // user explicitly opted out
  dispatched  Boolean  @default(false)  // we've already sent a bot
  botId       String?
  meetingId   String?
  updatedAt   DateTime @updatedAt
}

model Question {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id])
  askerName  String?
  question   String
  // Captured prompt that was sent to the MCP for the answer below.
  // Stored so we can run prompt evals later.
  mcpPrompt  String?
  answer     String
  latencyMs  Int?
  createdAt  DateTime @default(now())
}
